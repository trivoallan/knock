#!/usr/bin/env sh
# Fake vuln evaluator for integration tests. Emits SARIF on stdout per FAKE_GRYPE_SCENARIO;
# appends argv to FAKE_GRYPE_LOG (if set) for argument assertions.
set -e
[ -n "${FAKE_GRYPE_LOG:-}" ] && printf '%s\n' "$*" >> "$FAKE_GRYPE_LOG"
scenario="${FAKE_GRYPE_SCENARIO:-clean}"
case "$scenario" in
    clean)      printf '{"$schema":"sarif","runs":[{"tool":{"driver":{"name":"grype","version":"0.80.0","rules":[]}},"results":[]}]}\n' ;;
    vulnerable) printf '{"$schema":"sarif","runs":[{"tool":{"driver":{"name":"grype","version":"0.80.0","rules":[{"id":"CVE-1","properties":{"security-severity":"9.8"}}]}},"results":[{"ruleId":"CVE-1","level":"error","properties":{"security-severity":"9.8"}}]}]}\n' ;;
    fail)       echo "grype boom" >&2; exit 1 ;;
    garbage)    printf 'not json\n' ;;
    *)          printf '{"runs":[]}\n' ;;
esac
