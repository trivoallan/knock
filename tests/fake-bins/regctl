#!/usr/bin/env sh
# Fake regctl for integration tests.
# Reads are selected by FAKE_REGCTL_SCENARIO; every call's argv is appended to
# FAKE_REGCTL_LOG (if set) so tests can assert on exact write arguments.
set -e

[ -n "${FAKE_REGCTL_LOG:-}" ] && echo "$@" >> "$FAKE_REGCTL_LOG"

scenario="${FAKE_REGCTL_SCENARIO:-default}"

# Global failure simulation (covers read AND write commands).
if [ "$scenario" = "fail" ]; then
    echo "regctl: simulated failure" >&2
    exit 1
fi

cmd="$1 $2"
case "$cmd" in
    "tag ls")
        case "$scenario" in
            tags-redis) printf '7.2.0\n7.3.0\nlatest\n' ;;
            empty) : ;;
            notfound)
                echo 'failed: NAME_UNKNOWN: repository name not known to registry' >&2
                exit 1 ;;
            apply-fail-boom)
                # Source repos (docker.io) carry a tag so BOTH policies reach apply;
                # destination repos (harbor.corp) are empty so the good policy imports.
                case "$*" in
                    *docker.io*) printf '7.2.0\n' ;;
                    *) : ;;
                esac ;;
            *) printf '7.2.0\n' ;;
        esac
        ;;
    "repo ls")
        case "$scenario" in
            repos) printf 'lib/redis\nlib/nginx\n' ;;
            coverage-covered) printf 'lib/redis\n' ;;
            *) : ;;
        esac
        ;;
    "image digest")
        printf 'sha256:abc123\n'
        ;;
    "manifest get")
        if [ "$scenario" = "garbage" ]; then
            printf 'not json\n'
        elif [ "$scenario" = "manifest-array" ]; then
            printf '[]\n'
        elif [ "$scenario" = "mirror-stamped" ]; then
            printf '{"annotations":{"org.opencontainers.image.base.digest":"sha256:src999"}}\n'
        elif [ "$scenario" = "coverage-covered" ]; then
            printf '{"annotations":{"io.houba.policy":"redis"}}\n'
        else
            printf '{"annotations":{}}\n'
        fi
        ;;
    "image config")
        # Apply-phase failure for the 'boom' policy only: its source inspect
        # (image config docker.io/library/boom:...) blows up, while the good
        # policy's inspect succeeds. Read happens in apply, so the run is partial.
        case "$scenario" in
            apply-fail-boom)
                case "$*" in
                    *boom*)
                        echo 'regctl: simulated apply failure on boom' >&2
                        exit 1 ;;
                esac
                printf '{"created":"2026-01-02T03:04:05Z","architecture":"amd64","os":"linux"}\n' ;;
            garbage) printf 'not json\n' ;;
            created-invalid) printf '{"created":"not-a-date","architecture":"amd64"}\n' ;;
            no-created) printf '{"architecture":"amd64","os":"linux"}\n' ;;
            config-labels) printf '{"created":"2026-01-02T03:04:05Z","architecture":"amd64","config":{"Labels":{"org.opencontainers.image.revision":"9fceb02commit"}}}\n' ;;
            *) printf '{"created":"2026-01-02T03:04:05Z","architecture":"amd64","os":"linux"}\n' ;;
        esac
        ;;
    "registry login"|"registry set")
        : ;;
    "image copy"|"image mod"|"tag rm"|"manifest delete")
        : ;;
    "artifact list")
        case "$scenario" in
            referrers-one)
                printf '{"descriptors":[{"digest":"sha256:ref1","artifactType":"application/vnd.houba.lifecycle.pending+json","annotations":{}}]}\n' ;;
            referrers-empty)
                printf '{"descriptors":[]}\n' ;;
            *) printf '{"descriptors":[]}\n' ;;
        esac
        ;;
    "artifact put")
        # Serves put_referrer: annotation-only (no blob; stdout ignored) and
        # blob-carrying (returns the referrer digest).
        printf 'harbor.corp/lib/redis@sha256:ref123\n'
        ;;
    *)
        echo "fake-regctl: unknown command '$cmd'" >&2
        exit 99
        ;;
esac
